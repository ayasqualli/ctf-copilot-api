# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# GitHub webhook
# Generate a long random value and set the same value in GitHub repo Settings -> Webhooks.
GITHUB_WEBHOOK_SECRET=change_me_to_a_long_random_secret

# Vault sync
# For private repos, prefer SSH deploy key or an HTTPS token with read-only contents permissions.
VAULT_REPO_URL=git@github.com:ayasqualli/Notes-Sync.git
VAULT_BRANCH=main
VAULT_LOCAL_PATH=./vault-cache

# Database
DATABASE_PATH=./data/notes.db

# AI routing
# Use "mock" for local tests/demo without AI keys. Use "portkey" for the real assignment demo.
AI_PROVIDER=portkey
AI_MODEL=@your-provider-slug/claude-sonnet-4-5-20250929
AI_MAX_TOKENS=1800
AI_TEMPERATURE=0

# Portkey
PORTKEY_API_KEY=ZUuXmWwg52tPo1SgeQGMGBqN5M8j
PORTKEY_PROVIDER=anthropic
PORTKEY_BASE_URL=https://api.portkey.ai/v1/messages
PORTKEY_REQUEST_TIMEOUT_MS=45000
