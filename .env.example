#Example .env file to run the project locally

# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# GitHub webhook
# Generate a long random value and set the same value in GitHub repo Settings -> Webhooks.
GITHUB_WEBHOOK_SECRET=add-your-long-random-secret_key
#generate using `openssl rand -hex 32` in your terminal

# Vault sync
# For private repos, prefer SSH deploy key or an HTTPS token with read-only contents permissions.
VAULT_REPO_URL=add-your-github-repo-link-here
VAULT_BRANCH=main
VAULT_LOCAL_PATH=./vault-cache

# Database
DATABASE_PATH=./data/notes.db

# AI routing
# Use "mock" for local tests/demo without AI keys. Use "portkey" for the real assignment demo.
AI_PROVIDER=portkey
AI_MODEL=@your-provider-slug/your-used-model
AI_MAX_TOKENS=1800
AI_TEMPERATURE=0

# Portkey
PORTKEY_API_KEY=pk..
PORTKEY_PROVIDER=add-it-if-no-slug-is-attached
PORTKEY_BASE_URL=https://api.portkey.ai/v1/chat/completions
#Change it following the portkey config
PORTKEY_REQUEST_TIMEOUT_MS=45000
